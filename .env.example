# Gemini API Key (已弃用，建议使用国内 AI)
# GEMINI_API_KEY="your_gemini_api_key_here"

# ============================================
# AI 配置 - 硅基流动（推荐，免费额度充足）
# ============================================
# 获取地址：https://cloud.siliconflow.cn
VITE_AI_API_KEY="sk-your-api-key"

# API 地址（硅基流动默认）
VITE_AI_BASE_URL="https://api.siliconflow.cn/v1"

# 模型选择（硅基流动支持的免费模型）
# DeepSeek V2.5（推荐）- 高性价比
VITE_AI_MODEL="deepseek-ai/DeepSeek-V2.5"

# Qwen2.5（备选）- 支持更长上下文
# VITE_AI_MODEL="Qwen/Qwen2.5-72B-Instruct"

# ============================================
# 备选：DeepSeek 官方 API
# ============================================
# 获取地址：https://platform.deepseek.com
# VITE_AI_API_KEY="your-deepseek-api-key"
# VITE_AI_BASE_URL="https://api.deepseek.com/v1"
# VITE_AI_MODEL="deepseek-chat"

# ============================================
# 备选：智谱 AI
# ============================================
# 获取地址：https://open.bigmodel.cn
# VITE_AI_API_KEY="your-zhipu-api-key"
# VITE_AI_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
# VITE_AI_MODEL="glm-4-flash"
